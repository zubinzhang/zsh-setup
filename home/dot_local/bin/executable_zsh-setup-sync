#!/usr/bin/env bash

set -euo pipefail

INSTALL_HOME="${ZSH_SETUP_HOME:-${XDG_DATA_HOME:-${HOME}/.local/share}/zsh-setup}"
SCRIPT_PATH="${INSTALL_HOME}/scripts/sync.sh"

if [[ ! -x "${SCRIPT_PATH}" ]]; then
	printf '[zsh-setup] ERROR: managed sync script is missing: %s\n' "${SCRIPT_PATH}" >&2
	exit 1
fi

exec "${SCRIPT_PATH}" "$@"
